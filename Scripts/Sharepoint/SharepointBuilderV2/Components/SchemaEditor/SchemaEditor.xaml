<TabItem xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Header="##loc:sp_builder.tab_schema_editor##" ToolTip="Gérer les types de contenus et colonnes">
    <Grid Background="{DynamicResource BackgroundLightBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Workspace -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- 1. BARRE D'OUTILS & CONTEXTE -->
        <Border Grid.Row="0" Background="{DynamicResource WhiteBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Gestion Fichier -->
                    <ColumnDefinition Width="*"/>
                    <!-- Espace -->
                </Grid.ColumnDefinitions>

                <!-- Gestion BDD -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="##loc:sp_builder.label_existing_schema##" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ComboBox x:Name="SchemaLoadComboBox" Width="200" Style="{DynamicResource StandardComboBoxStyle}" Height="32" ToolTip="Sélectionner un modèle de dossier avancé"/>
                    </StackPanel>
                    <Button x:Name="SchemaLoadButton" Content="##loc:sp_builder.btn_load##" Style="{DynamicResource SecondaryButtonStyle}" Height="38" VerticalAlignment="Bottom" ToolTip="Charger ce modèle"/>
                    <Button x:Name="SchemaDeleteButton" Content="🗑️" Style="{DynamicResource SecondaryButtonStyle}" Height="38" Width="40" Padding="0" VerticalAlignment="Bottom" Margin="5,0,0,0" Foreground="{DynamicResource DangerBrush}" ToolTip="Supprimer le modèle sélectionné"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. ZONE DE TRAVAIL -->
        <Grid Grid.Row="1" Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <!-- Formulaire -->
                <ColumnDefinition Width="25"/>
                <!-- Espace -->
                <ColumnDefinition Width="2.5*"/>
                <!-- Liste des colonnes -->
            </Grid.ColumnDefinitions>

            <!-- COLONNE GAUCHE : DÉFINITION GLOBALE -->
            <Border Grid.Column="0" Style="{DynamicResource CardBorderStyle}" Padding="0" VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="15,10" CornerRadius="10,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Margin="0,0,10,0"/>
                            <TextBlock Text="Paramètres du Modèle" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="20">
                        <TextBlock Text="Nom du Modèle de Dossier :" Style="{DynamicResource H4Style}"/>
                        <TextBox x:Name="SchemaNameTextBox" Style="{DynamicResource StandardTextBoxStyle}" Margin="0,5,0,20" ToolTip="Ex: Dossier de Projet, Dossier Technique..."/>

                        <TextBlock Text="Description interne :" Style="{DynamicResource H4Style}"/>
                        <TextBox x:Name="SchemaDescTextBox" Style="{DynamicResource StandardTextBoxStyle}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,20"/>
                        
                        <TextBlock Text="Ce composant va générer un 'Type de Contenu' (Content Type) dans SharePoint incluant les colonnes listées à droite, et l'ajoutera aux bibliothèques lors du déploiement." Style="{DynamicResource H6Style}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- COLONNE DROITE : COLONNES (SCHÉMA) -->
            <Border Grid.Column="2" Style="{DynamicResource CardBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource BackgroundLightBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="15,10" CornerRadius="10,10,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📊" Margin="0,0,10,0"/>
                                <TextBlock Text="Colonnes SharePoint (Taxonomie)" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button x:Name="SchemaAddColumnButton" Content="+ Ajouter une colonne" Style="{DynamicResource PrimaryButtonStyle}" Height="30" HorizontalAlignment="Right" Padding="10,0"/>
                        </Grid>
                    </Border>

                    <!-- EN-TETE ET LISTE DES COLONNES -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20,15,20,20">
                            <!-- En-tête -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0" ToolTip="Nom interne sans espace obligatoire">
                                    <TextBlock Text="Nom système de la colonne " Style="{DynamicResource H6Style}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="*" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0" ToolTip="Format des données en BDD">
                                    <TextBlock Text="Type de donnée " Style="{DynamicResource H6Style}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="*" Foreground="Red" FontWeight="Bold"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="Indexable" ToolTip="Optimiser la recherche (Limité à 20 min/max)" Style="{DynamicResource H6Style}" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            </Grid>

                            <!-- Conteneur Items WPF -->
                            <ItemsControl x:Name="SchemaColumnsContainer">
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <Border Grid.Row="3" Background="#F9F9F9" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="15" CornerRadius="0,0,10,10">
                        <TextBlock Text="ℹ️ Assurez-vous d'utiliser des noms de colonnes sans espaces ni caractères spéciaux. L'option 'Indexable' accélère la recherche SharePoint mais est limitée." FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Editeur -->
        <Border Grid.Row="2" Background="{DynamicResource WhiteBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Text -->
                <TextBlock Grid.Column="0" x:Name="SchemaStatusText" Text="##loc:sp_builder.msg_ready##" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Actions Globales -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SchemaNewButton" Content="##loc:sp_builder.btn_new##" Style="{DynamicResource SecondaryButtonStyle}" Height="36" Margin="0,0,10,0" ToolTip="Créer un nouveau modèle vierge"/>
                    <Button x:Name="SchemaSaveButton" Content="##loc:sp_builder.btn_save##" Style="{DynamicResource PrimaryButtonStyle}" Height="36" ToolTip="Enregistrer ce modèle (JSON) en base de données"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</TabItem>
